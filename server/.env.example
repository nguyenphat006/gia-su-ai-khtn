# ============================
# SERVER
# ============================
PORT=3001
NODE_ENV=development

# ============================
# CORS
# ============================
ALLOWED_ORIGINS="http://localhost:3000"

# ============================
# DATABASE (PostgreSQL)
# Cấu trúc: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME?schema=public
# ============================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ai_khtn_db?schema=public"

# ============================
# AUTH / JWT
# ============================
# Secret chung để ký JWT (dùng bởi token.ts)
JWT_SECRET="your-jwt-secret-here"

# Secret riêng cho access/refresh token (dùng bởi jwt.ts)
JWT_ACCESS_SECRET="your-access-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# Thời gian sống của Access Token (phút)
ACCESS_TOKEN_TTL_MINUTES=15

# Thời gian sống của Refresh Token (ngày)
REFRESH_TOKEN_TTL_DAYS=7

# Thời gian sống — dùng bởi jwt.ts
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN_DAYS=7

# ============================
# GOOGLE GEMINI AI
# Lấy API Key tại: https://aistudio.google.com/app/apikey
# ============================
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ============================
# FIREBASE ADMIN
# ============================
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_DATABASE_ID="your-firebase-database-id"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
